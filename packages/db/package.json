{
  "name": "@racedash/db",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run --exclude 'test/helpers/{credits,licenses,slots}.test.ts'",

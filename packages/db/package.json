    "drizzle-orm": "^0.38.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.0",
    "fast-check": "^4.0.0",
    "pg": "^8.13.0",
    "typescript": "*",
    "vitest": "*"
  }
}

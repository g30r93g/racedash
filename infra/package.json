{
  "name": "@racedash/infra",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest --config jest.config.ts",
    "localstack:env": "cat localstack-init/env.localstack > .env.localstack",
    "localstack:up": "docker compose -f docker-compose.localstack.yml up -d && ../scripts/wait-for-localstack.sh",
    "localstack:down": "docker compose -f docker-compose.localstack.yml down",
    "localstack:fresh": "docker compose -f docker-compose.localstack.yml down -v && docker compose -f docker-compose.localstack.yml up -d && ../scripts/wait-for-localstack.sh",
    "localstack:reset": "pnpm localstack:down && pnpm localstack:up",
    "localstack:logs": "docker compose -f docker-compose.localstack.yml logs -f",
    "test:local": "pnpm localstack:up && pnpm localstack:env && NODE_OPTIONS='--experimental-vm-modules' dotenv -e .env.localstack -- jest --config jest.localstack.config.ts && pnpm localstack:down",
    "test:local:watch": "NODE_OPTIONS='--experimental-vm-modules' dotenv -e .env.localstack -- jest --config jest.localstack.config.ts --watch",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy": "cdk deploy",
    "diff": "cdk diff"
  },
  "dependencies": {
    "@aws-sdk/client-ecs": "^3.1013.0",
    "@aws-sdk/client-eventbridge": "^3.1013.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-ses": "^3.700.0",
    "@aws-sdk/client-sfn": "^3.700.0",
    "@aws-sdk/client-sqs": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.1013.0",
    "@racedash/db": "workspace:*",
    "aws-cdk-lib": "^2.180.0",
    "constructs": "^10.4.2",
    "drizzle-orm": "^0.38.0",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1016.0",
    "@aws-sdk/client-lambda": "^3.1016.0",
    "@remotion/lambda": "^4.0.0",
    "@types/aws-lambda": "^8.10.161",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "aws-cdk": "^2.180.0",
    "dotenv-cli": "^8.0.0",
    "esbuild": "^0.27.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}

# ---------------------------------------------------------------------------
# @racedash/web-marketing
#
# Copy this file to `.env.local` and fill in real values for local development.
# Production values are set per-environment in the Vercel project dashboard.
# ---------------------------------------------------------------------------

# -- Clerk (account pages) --------------------------------------------------
# Required for /account, /account/create, /account/authenticate to work.
# Without these set, the routes still build but the forms will render a
# loading spinner forever because Clerk hooks never initialize.
#
# Create a Clerk application at https://dashboard.clerk.com and paste the
# keys from the "API Keys" panel.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Where Clerk redirects users when the forms finish. Keep these in sync with
# the marketing site's /account routes.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/en/account/authenticate
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/en/account/create
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/en/account
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/en/account

# -- RaceDash API -----------------------------------------------------------
# Base URL for the API that backs the waitlist endpoint. The marketing site
# forwards POST /api/waitlist to RACEDASH_API_URL/waitlist server-side.
RACEDASH_API_URL=https://api.racedash.io
